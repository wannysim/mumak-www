{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalDependencies": ["package.json", "pnpm-lock.yaml", "turbo.json", ".env*"],
  "globalEnv": ["NODE_ENV", "CI", "VERCEL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "out/**", "*.tsbuildinfo"],
      "env": ["NEXT_PUBLIC_*", "ANALYZE"],
      "passThroughEnv": [
        "NODE_ENV",
        "E2E_INCLUDE_DRAFT",
        "SPOTIFY_CLIENT_ID",
        "SPOTIFY_CLIENT_SECRET",
        "SPOTIFY_REFRESH_TOKEN"
      ]
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/.oxlintrc.json"],
      "outputs": []
    },
    "lint:fix": {
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/.oxlintrc.json"],
      "cache": false
    },
    "//#lint:root": {
      "inputs": [
        "scripts/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts}",
        ".cursor/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts}",
        ".agents/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts}",
        "*.{ts,tsx,js,jsx,mjs,cjs,mts,cts}",
        ".oxlintrc.json"
      ],
      "outputs": []
    },
    "//#lint:root:fix": {
      "inputs": [
        "scripts/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts}",
        ".cursor/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts}",
        ".agents/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts}",
        "*.{ts,tsx,js,jsx,mjs,cjs,mts,cts}",
        ".oxlintrc.json"
      ],
      "cache": false
    },
    "format": {
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/.oxfmtrc.jsonc"],
      "outputs": []
    },
    "format:fix": {
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/.oxfmtrc.jsonc"],
      "cache": false
    },
    "format:check": {
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/.oxfmtrc.jsonc"],
      "outputs": []
    },
    "//#format:root:check": {
      "inputs": [
        "scripts/**",
        ".cursor/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json,jsonc,json5,yaml,yml,md,mdx}",
        ".agents/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json,jsonc,json5,yaml,yml,md,mdx}",
        "*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json,jsonc,json5,yaml,yml,md,mdx,css,scss,less,html}",
        ".oxfmtrc.jsonc"
      ],
      "outputs": []
    },
    "//#format:root:fix": {
      "inputs": [
        "scripts/**",
        ".cursor/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json,jsonc,json5,yaml,yml,md,mdx}",
        ".agents/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json,jsonc,json5,yaml,yml,md,mdx}",
        "*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json,jsonc,json5,yaml,yml,md,mdx,css,scss,less,html}",
        ".oxfmtrc.jsonc"
      ],
      "cache": false
    },
    "check-types": {
      "dependsOn": ["^build", "build"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig*.json"],
      "outputs": []
    },
    "knip": {
      "inputs": ["$TURBO_DEFAULT$", "knip.config.ts", "**/*.{ts,tsx,js,jsx}"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build", "build"],
      "inputs": ["$TURBO_DEFAULT$", "jest.config.*", "vitest.config.*"],
      "outputs": ["coverage/**"],
      "passThroughEnv": ["SPOTIFY_CLIENT_ID", "SPOTIFY_CLIENT_SECRET", "SPOTIFY_REFRESH_TOKEN"]
    },
    "test:coverage": {
      "dependsOn": ["^build", "build"],
      "inputs": ["$TURBO_DEFAULT$", "jest.config.*", "vitest.config.*"],
      "outputs": ["coverage/**"],
      "passThroughEnv": ["SPOTIFY_CLIENT_ID", "SPOTIFY_CLIENT_SECRET", "SPOTIFY_REFRESH_TOKEN"]
    },
    "test:ci": {
      "dependsOn": ["^build", "build"],
      "inputs": ["$TURBO_DEFAULT$", "jest.config.*", "vitest.config.*"],
      "outputs": ["coverage/**"],
      "passThroughEnv": ["SPOTIFY_CLIENT_ID", "SPOTIFY_CLIENT_SECRET", "SPOTIFY_REFRESH_TOKEN"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "inputs": ["$TURBO_DEFAULT$", "**/*.{ts,tsx,js,jsx}", "e2e/**/*", "playwright.config.*"],
      "outputs": ["test-results/**", "playwright-report/**"],
      "passThroughEnv": ["PLAYWRIGHT_*", "CI", "SPOTIFY_CLIENT_ID", "SPOTIFY_CLIENT_SECRET", "SPOTIFY_REFRESH_TOKEN"]
    },
    "validate:content": {
      "inputs": ["content/**/*.mdx", "scripts/validate-content.mjs"],
      "outputs": []
    },
    "validate:garden": {
      "inputs": ["content/**/garden/**/*.mdx", "scripts/validate-garden.mjs"],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
