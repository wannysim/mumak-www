{
  "name": "mumak-www",
  "version": "1.6.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint lint:root",
    "lint:fix": "turbo run lint:fix lint:root:fix",
    "lint:root": "oxlint --ignore-pattern 'apps/**' --ignore-pattern 'packages/**' .",
    "lint:root:fix": "oxlint --fix --ignore-pattern 'apps/**' --ignore-pattern 'packages/**' .",
    "format": "turbo run format:check format:root:check",
    "format:fix": "turbo run format:fix format:root:fix",
    "format:check": "turbo run format:check format:root:check",
    "format:root:check": "oxfmt --check . '!apps/**' '!packages/**'",
    "format:root:fix": "oxfmt . '!apps/**' '!packages/**'",
    "quality": "turbo run lint lint:root format:check format:root:check",
    "quality:fix": "turbo run lint:fix lint:root:fix format:fix format:root:fix",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:ci": "turbo run test:ci",
    "test:e2e": "turbo run test:e2e",
    "knip": "knip",
    "turbo:dry": "turbo run build test --dry-run",
    "turbo:dry:json": "turbo run build test --dry-run=json",
    "turbo:graph": "turbo run build --graph",
    "turbo:clean": "turbo run clean && rm -rf node_modules .turbo",
    "affected": "pnpm quality && turbo run build test --filter='[HEAD^1]'",
    "affected:dry": "pnpm turbo run build test --filter='[HEAD^1]' --dry-run",
    "prepare": "husky",
    "version:sync": "node scripts/sync-versions.mjs",
    "version:check": "node scripts/sync-versions.mjs --check"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint-plugin-turbo": "^2.9.5",
    "husky": "^9.0.11",
    "knip": "^5.86.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "turbo": "^2.9.5",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,mts,cts}": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.{md,mdx,json,jsonc,json5,yaml,yml,css,scss,less,html}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "engines": {
    "node": ">=24.11.1"
  },
  "packageManager": "pnpm@10.33.1"
}
